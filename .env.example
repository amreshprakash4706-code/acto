# ============================================
# Atconiz – Environment Variables
# ============================================
# Get a free Gemini API key: https://aistudio.google.com/apikey
# NEVER commit the real .env file.
# Add the real key in Vercel → Settings → Environment Variables (Production + Preview).

GEMINI_API_KEY=your_gemini_api_key_here

# Optional future keys
# NEXT_PUBLIC_SITE_URL=https://atconiz.vercel.app
# SENTRY_DSN=
